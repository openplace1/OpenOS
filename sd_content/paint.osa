#app "Paint"
#isApp true
#appColor "#FF3B30"

# Drain the launching tap so the first stroke doesn't start on it.
wait(120)
while touch.down() == 1 do wait(20) end

var curIdx = 0
var brush  = 3
var prevX  = 0 - 1
var prevY  = 0 - 1

# ─── Palette ────────────────────────────────────────────────────────────────
def applyColor()
  if curIdx == 0 then setcolor(0, 0, 0) end
  if curIdx == 1 then setcolor(255, 255, 255) end
  if curIdx == 2 then setcolor(255, 60, 60) end
  if curIdx == 3 then setcolor(255, 150, 0) end
  if curIdx == 4 then setcolor(255, 230, 0) end
  if curIdx == 5 then setcolor(40, 220, 60) end
  if curIdx == 6 then setcolor(0, 120, 255) end
  if curIdx == 7 then setcolor(220, 60, 220) end
end

def drawSwatch(i)
  var x = 4 + i * 26
  if i == 0 then setcolor(0, 0, 0) end
  if i == 1 then setcolor(255, 255, 255) end
  if i == 2 then setcolor(255, 60, 60) end
  if i == 3 then setcolor(255, 150, 0) end
  if i == 4 then setcolor(255, 230, 0) end
  if i == 5 then setcolor(40, 220, 60) end
  if i == 6 then setcolor(0, 120, 255) end
  if i == 7 then setcolor(220, 60, 220) end
  rect(x, 4, 24, 28)
end

def drawToolbar()
  setcolor(35, 35, 40)
  rect(0, 0, 240, 36)
  var i = 0
  while i < 8 do
    drawSwatch(i)
    i = i + 1
  end
  # Selected swatch outline
  var sx = 4 + curIdx * 26
  setcolor(255, 255, 255)
  frame(sx - 1, 3, 26, 30)
  setcolor(0, 0, 0)
  frame(sx, 4, 24, 28)
  # Clear button on the right edge
  setcolor(120, 30, 30)
  rect(212, 4, 24, 28)
  setcolor(255, 255, 255)
  fontsize(2)
  textc(224, 18, "C")
end

def clearCanvas()
  setcolor(245, 245, 250)
  rect(0, 36, 240, 284)
end

# Thick line — draws several parallel lines in a cross pattern so fast
# strokes don't leave thin gaps between the per-frame circles.
def stroke(x0, y0, x1, y1)
  var dr = 0 - brush
  while dr <= brush do
    line(x0 + dr, y0, x1 + dr, y1)
    line(x0, y0 + dr, x1, y1 + dr)
    dr = dr + 1
  end
end

# ─── Setup ──────────────────────────────────────────────────────────────────
bg(15, 15, 20)
clearCanvas()
drawToolbar()
applyColor()

# ─── Main loop ──────────────────────────────────────────────────────────────
loop
  if touch.down() == 0 then
    prevX = 0 - 1
    prevY = 0 - 1
    wait(15)
  end
  if touch.down() == 1 then
    var tx = touch.x()
    var ty = touch.y()

    if ty < 36 then
      # Toolbar tap — clear button or palette swatch.
      if tx >= 212 then
        clearCanvas()
      end
      if tx < 212 then
        var i = 0
        while i < 8 do
          var sx = 4 + i * 26
          if tx >= sx then
            if tx < sx + 24 then curIdx = i end
          end
          i = i + 1
        end
        drawToolbar()
        applyColor()
      end
      while touch.down() == 1 do wait(15) end
      prevX = 0 - 1
      prevY = 0 - 1
    end

    if ty >= 36 then
      circle(tx, ty, brush)
      if prevX >= 0 then
        stroke(prevX, prevY, tx, ty)
      end
      prevX = tx
      prevY = ty
    end
  end
end
